# .env.example — copy to .env and fill in secrets before `docker compose up`.
#
# Only values actually consumed by the W1a infra slice are listed here.
# Additional variables (JWT_SECRET, service URLs, etc.) arrive with W1b.

# PostgreSQL superuser for the shared `deep_analysis` database.
POSTGRES_USER=da
POSTGRES_PASSWORD=changeme

# Alembic / database migrations.
# Used by `alembic upgrade head` and related commands; overrides the
# placeholder sqlalchemy.url in alembic.ini. Compose maps postgres to
# localhost:5432 by default.
DATABASE_URL=postgresql+psycopg://da:changeme@localhost:5432/deep_analysis

# Service-to-service configuration (W1b-iii)
DA_REDIS_URL=redis://redis:6379/0
DA_JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
DA_LOG_LEVEL=INFO

# Auth service — JWT signing (W2b). The private key is only mounted
# into the `auth` container; every other service mounts the public key
# via DA_JWT_PUBLIC_KEY_PATH. Generate with:
#   uv run python -m auth_service.keygen --out ./secrets/
DA_JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
DA_ACCESS_TOKEN_TTL_SECONDS=900
DA_REFRESH_TOKEN_TTL_SECONDS=2592000

# Per-service database URLs (fill in W2 when roles are created)
# DA_DATABASE_URL=postgresql+asyncpg://da:changeme@postgres:5432/deep_analysis

# First-boot admin bootstrap (W2e). Leave unset for the auto-generate
# path — a random password will be written to
# /data/secrets/initial_admin.txt on the `auth_secrets` named volume.
# Set BOTH to bypass the random-password path for scripted installs;
# no plaintext file is written in that case.
# DEEP_ANALYSIS_BOOTSTRAP_ADMIN_EMAIL=admin@sentania.net
# DEEP_ANALYSIS_BOOTSTRAP_ADMIN_PASSWORD=<set-if-you-want-scripted-install>

# Caddy / ACME
# The public hostname Caddy serves and obtains a certificate for.
GATEWAY_DOMAIN=deepanalysis.sentania.net
# Let's Encrypt contact email for ACME certificate issuance.
DEEP_ANALYSIS_ACME_EMAIL=ops@example.com
